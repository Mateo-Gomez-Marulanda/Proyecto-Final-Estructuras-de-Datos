<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyectofinal.controllers.AsesoresController"
      spacing="16" styleClass="content-area">

    <!-- Encabezado -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Asesores" styleClass="modulo-titulo"/>
            <Label text="Gestión del equipo de asesores inmobiliarios" styleClass="modulo-subtitulo"/>
        </VBox>
        <Button text="➕  Registrar asesor"
                styleClass="boton-primario"
                onAction="#abrirFormularioRegistro"/>
    </HBox>

    <!-- Barra de búsqueda -->
    <HBox styleClass="barra-filtros" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="campoBusqueda"
                   styleClass="campo-busqueda"
                   promptText="Buscar por nombre, ID o zona..."
                   onKeyReleased="#filtrarTabla"/>
        <ComboBox fx:id="filtroZona"
                  styleClass="combo-filtro"
                  promptText="Especialidad / zona"
                  onAction="#filtrarTabla"/>
        <Button text="Limpiar"
                styleClass="boton-secundario"
                onAction="#limpiarFiltros"/>
    </HBox>

    <!-- Contenido: tabla + panel de detalle -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Tabla de asesores -->
        <TableView fx:id="tablaAsesores"
                   styleClass="tabla-principal"
                   HBox.hgrow="ALWAYS"
                  >
            <placeholder><Label text="No hay asesores registrados."/></placeholder>
            <columns>
                <TableColumn fx:id="colIdentificacion"  text="Identificación"  prefWidth="130"/>
                <TableColumn fx:id="colNombre"           text="Nombre"          prefWidth="180"/>
                <TableColumn fx:id="colContacto"         text="Contacto"        prefWidth="140"/>
                <TableColumn fx:id="colZona"             text="Zona / Esp."     prefWidth="140"/>
                <TableColumn fx:id="colCierres"          text="Cierres"         prefWidth="75"/>
                <TableColumn fx:id="colInmuebles"        text="Inmuebles asig." prefWidth="120"/>
            </columns>
        </TableView>

        <!-- Panel de detalle del asesor seleccionado -->
        <VBox fx:id="panelDetalle"
              prefWidth="250" minWidth="220"
              spacing="12"
              style="-fx-background-color: white; -fx-background-radius: 10px; -fx-padding: 16px; -fx-border-color: #e2e8f0; -fx-border-width: 1px; -fx-border-radius: 10px;"
              visible="false">
            <Label text="Detalle del asesor"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
            <Separator/>
            <Label fx:id="detalleNombre"    text="—" wrapText="true"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Label fx:id="detalleContacto"  text="—" wrapText="true"
                   style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <Label fx:id="detalleZona"      text="—" wrapText="true"
                   style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <Label fx:id="detalleCierres"   text="—"
                   style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            <Separator/>
            <Label text="Inmuebles asignados:"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <ListView fx:id="listaInmueblesAsesor"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1px; -fx-background-radius: 6px;">
                <placeholder><Label text="Sin inmuebles asignados."/></placeholder>
            </ListView>
        </VBox>

    </HBox>

    <!-- Barra de acciones -->
    <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
        <Button text="✏️  Editar"
                fx:id="btnEditar"
                styleClass="boton-secundario"
                onAction="#editarAsesorSeleccionado"
                disable="true"/>
        <Button text="🗑️  Eliminar"
                fx:id="btnEliminar"
                styleClass="boton-peligro"
                onAction="#eliminarAsesorSeleccionado"
                disable="true"/>
        <Button text="🏢  Gestionar inmuebles"
                fx:id="btnGestionarInmuebles"
                styleClass="boton-secundario"
                onAction="#gestionarInmueblesAsesor"
                disable="true"/>
    </HBox>

</VBox>
