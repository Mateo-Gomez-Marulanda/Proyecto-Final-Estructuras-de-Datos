<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="proyectofinal.controllers.RegisterController"
           styleClass="login-fondo"
           stylesheets="@../css/estilos.css">

    <VBox styleClass="login-card" alignment="CENTER" spacing="0">

        <!-- Logo / título -->
        <VBox alignment="CENTER" spacing="6">
            <Label text="🏠 PropTech" styleClass="login-titulo"/>
            <Label text="Crear nueva cuenta" styleClass="login-subtitulo"/>
        </VBox>

        <Separator>
            <VBox.margin><Insets top="20" bottom="20"/></VBox.margin>
        </Separator>

        <!-- Campo: nombre completo -->
        <VBox spacing="6">
            <Label text="Nombre completo" styleClass="login-label"/>
            <TextField fx:id="campoNombre"
                       styleClass="login-campo"
                       promptText="Ingresa tu nombre completo"/>
        </VBox>

        <!-- Campo: identificación -->
        <VBox spacing="6">
            <VBox.margin><Insets top="12"/></VBox.margin>
            <Label text="Identificación" styleClass="login-label"/>
            <TextField fx:id="campoId"
                       styleClass="login-campo"
                       promptText="Número de documento"/>
        </VBox>

        <!-- Campo: correo -->
        <VBox spacing="6">
            <VBox.margin><Insets top="12"/></VBox.margin>
            <Label text="Correo electrónico" styleClass="login-label"/>
            <TextField fx:id="campoCorreo"
                       styleClass="login-campo"
                       promptText="correo@ejemplo.com"/>
        </VBox>

        <!-- Campo: teléfono -->
        <VBox spacing="6">
            <VBox.margin><Insets top="12"/></VBox.margin>
            <Label text="Teléfono" styleClass="login-label"/>
            <TextField fx:id="campoTelefono"
                       styleClass="login-campo"
                       promptText="Número de contacto"/>
        </VBox>

        <!-- Campo: contraseña -->
        <VBox spacing="6">
            <VBox.margin><Insets top="12"/></VBox.margin>
            <Label text="Contraseña" styleClass="login-label"/>
            <PasswordField fx:id="campoContrasena"
                           styleClass="login-campo"
                           promptText="Crea una contraseña"/>
        </VBox>

        <!-- Campo: confirmar contraseña -->
        <VBox spacing="6">
            <VBox.margin><Insets top="12"/></VBox.margin>
            <Label text="Confirmar contraseña" styleClass="login-label"/>
            <PasswordField fx:id="campoConfirmarContrasena"
                           styleClass="login-campo"
                           promptText="Repite tu contraseña"/>
        </VBox>

        <!-- Mensaje de error / éxito -->
        <Label fx:id="mensajeFeedback"
               text=""
               wrapText="true"
               maxWidth="300"
               style="-fx-font-size: 12px;">
            <VBox.margin><Insets top="10"/></VBox.margin>
        </Label>

        <!-- Botón registrarse -->
        <Button fx:id="botonRegistrar"
                text="Crear cuenta"
                styleClass="login-boton"
                onAction="#manejarRegistro"
                defaultButton="true">
            <VBox.margin><Insets top="20"/></VBox.margin>
        </Button>

        <!-- Volver al login -->
        <HBox alignment="CENTER" spacing="6">
            <VBox.margin><Insets top="14"/></VBox.margin>
            <Label text="¿Ya tienes cuenta?"
                   style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
            <Button text="Inicia sesión"
                    styleClass="boton-link"
                    onAction="#volverAlLogin"/>
        </HBox>

        <!-- Versión -->
        <Label text="v1.0 · Proyecto Final ED"
               style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;">
            <VBox.margin><Insets top="12"/></VBox.margin>
        </Label>

    </VBox>

</StackPane>
