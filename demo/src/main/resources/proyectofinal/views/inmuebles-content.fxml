<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyectofinal.controllers.InmueblesController"
      spacing="16" styleClass="content-area">

    <!-- Encabezado -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Inmuebles" styleClass="modulo-titulo"/>
            <Label text="Gestión del catálogo de propiedades" styleClass="modulo-subtitulo"/>
        </VBox>
        <Button text="➕  Registrar inmueble"
                styleClass="boton-primario"
                onAction="#abrirFormularioRegistro"/>
    </HBox>

    <!-- Barra de búsqueda y filtros -->
    <HBox styleClass="barra-filtros" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="campoBusqueda"
                   styleClass="campo-busqueda"
                   promptText="Buscar por código, dirección o ciudad..."
                   onKeyReleased="#filtrarTabla"/>
        <ComboBox fx:id="filtroTipo"
                  styleClass="combo-filtro"
                  promptText="Tipo de inmueble"
                  onAction="#filtrarTabla"/>
        <ComboBox fx:id="filtroFinalidad"
                  styleClass="combo-filtro"
                  promptText="Finalidad"
                  onAction="#filtrarTabla"/>
        <ComboBox fx:id="filtroDisponibilidad"
                  styleClass="combo-filtro"
                  promptText="Disponibilidad"
                  onAction="#filtrarTabla"/>
        <Button text="Limpiar"
                styleClass="boton-secundario"
                onAction="#limpiarFiltros"/>
    </HBox>

    <!-- Tabla de inmuebles -->
    <TableView fx:id="tablaInmuebles"
               styleClass="tabla-principal"
               VBox.vgrow="ALWAYS"
              >
        <placeholder><Label text="No hay inmuebles registrados."/></placeholder>
        <columns>
            <TableColumn fx:id="colCodigo"       text="Código"       prefWidth="90"/>
            <TableColumn fx:id="colDireccion"    text="Dirección"    prefWidth="180"/>
            <TableColumn fx:id="colCiudad"       text="Ciudad"       prefWidth="100"/>
            <TableColumn fx:id="colTipo"         text="Tipo"         prefWidth="120"/>
            <TableColumn fx:id="colFinalidad"    text="Finalidad"    prefWidth="90"/>
            <TableColumn fx:id="colPrecio"       text="Precio"       prefWidth="110"/>
            <TableColumn fx:id="colArea"         text="Área m²"      prefWidth="80"/>
            <TableColumn fx:id="colEstado"       text="Estado"       prefWidth="100"/>
            <TableColumn fx:id="colDisponible"   text="Disponible"   prefWidth="85"/>
            <TableColumn fx:id="colAsesor"       text="Asesor"       prefWidth="130"/>
        </columns>
    </TableView>

    <!-- Barra de acciones inferior -->
    <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
        <Button text="✏️  Editar"
                fx:id="btnEditar"
                styleClass="boton-secundario"
                onAction="#editarInmuebleSeleccionado"
                disable="true"/>
        <Button text="🗑️  Eliminar"
                fx:id="btnEliminar"
                styleClass="boton-peligro"
                onAction="#eliminarInmuebleSeleccionado"
                disable="true"/>

        <!-- Separador visual -->
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Acciones de la Pila -->
        <Label text="Historial de cambios:"
               style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
        <Button text="↩  Deshacer último cambio"
                fx:id="btnDeshacerCambio"
                styleClass="boton-advertencia"
                onAction="#deshacerUltimoCambio"/>
        <Button text="↺  Revertir estado"
                fx:id="btnRevertirEstado"
                styleClass="boton-advertencia"
                onAction="#revertirUltimoCambioEstado"/>
        <Button text="📜  Ver historial"
                fx:id="btnVerHistorial"
                styleClass="boton-secundario"
                onAction="#verHistorialAcciones"/>
    </HBox>

</VBox>
