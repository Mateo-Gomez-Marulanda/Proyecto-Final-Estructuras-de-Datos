<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyectofinal.controllers.OperacionesController"
      spacing="16" styleClass="content-area">

    <!-- Encabezado -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Operaciones de negocio" styleClass="modulo-titulo"/>
            <Label text="Registro de arriendos, ventas y contratos" styleClass="modulo-subtitulo"/>
        </VBox>
        <Button text="➕  Registrar operación"
                styleClass="boton-primario"
                onAction="#abrirFormularioRegistro"/>
    </HBox>

    <!-- Tarjetas de resumen por tipo -->
    <HBox spacing="12">
        <VBox styleClass="stat-card" spacing="4" prefWidth="160">
            <Label text="🤝" styleClass="stat-icono-azul"/>
            <Label fx:id="numArriendos" text="0" styleClass="stat-numero"/>
            <Label text="Arriendos" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" prefWidth="160">
            <Label text="🏠" styleClass="stat-icono-verde"/>
            <Label fx:id="numVentas" text="0" styleClass="stat-numero"/>
            <Label text="Ventas" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" prefWidth="160">
            <Label text="🔄" styleClass="stat-icono-ambar"/>
            <Label fx:id="numRenovaciones" text="0" styleClass="stat-numero"/>
            <Label text="Renovaciones" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" prefWidth="160">
            <Label text="❌" styleClass="stat-icono-rojo"/>
            <Label fx:id="numCancelaciones" text="0" styleClass="stat-numero"/>
            <Label text="Cancelaciones" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <!-- Barra de búsqueda y filtros -->
    <HBox styleClass="barra-filtros" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="campoBusqueda"
                   styleClass="campo-busqueda"
                   promptText="Buscar por ID, cliente o inmueble..."
                   onKeyReleased="#filtrarTabla"/>
        <ComboBox fx:id="filtroTipoOperacion"
                  styleClass="combo-filtro"
                  promptText="Tipo de operación"
                  onAction="#filtrarTabla"/>
        <ComboBox fx:id="filtroEstado"
                  styleClass="combo-filtro"
                  promptText="Estado"
                  onAction="#filtrarTabla"/>
        <Button text="Limpiar"
                styleClass="boton-secundario"
                onAction="#limpiarFiltros"/>
    </HBox>

    <!-- Tabla de operaciones -->
    <TableView fx:id="tablaOperaciones"
               styleClass="tabla-principal"
               VBox.vgrow="ALWAYS"
              >
        <placeholder><Label text="No hay operaciones registradas."/></placeholder>
        <columns>
            <TableColumn fx:id="colId"           text="ID"          prefWidth="90"/>
            <TableColumn fx:id="colTipo"         text="Tipo"        prefWidth="130"/>
            <TableColumn fx:id="colInmueble"     text="Inmueble"    prefWidth="130"/>
            <TableColumn fx:id="colCliente"      text="Cliente"     prefWidth="150"/>
            <TableColumn fx:id="colAsesor"       text="Asesor"      prefWidth="130"/>
            <TableColumn fx:id="colValor"        text="Valor"       prefWidth="110"/>
            <TableColumn fx:id="colComision"     text="Comisión"    prefWidth="100"/>
            <TableColumn fx:id="colFecha"        text="Fecha"       prefWidth="100"/>
            <TableColumn fx:id="colEstadoProceso" text="Estado"     prefWidth="110"/>
        </columns>
    </TableView>

    <!-- Barra de acciones -->
    <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
        <Button text="📄  Ver detalles"
                fx:id="btnVerDetalles"
                styleClass="boton-secundario"
                onAction="#verDetallesOperacion"
                disable="true"/>
        <Button text="✏️  Editar estado"
                fx:id="btnEditarEstado"
                styleClass="boton-secundario"
                onAction="#editarEstadoOperacion"
                disable="true"/>
    </HBox>

</VBox>
