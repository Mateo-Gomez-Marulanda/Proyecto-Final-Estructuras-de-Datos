<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="proyectofinal.controllers.LoginController"
           styleClass="login-fondo"
           stylesheets="@../css/estilos.css">

    <VBox styleClass="login-card" alignment="CENTER" spacing="0">

        <!-- Logo / título -->
        <VBox alignment="CENTER" spacing="6">
            <Label text="🏠 PropTech" styleClass="login-titulo"/>
            <Label text="Sistema de gestión inmobiliaria" styleClass="login-subtitulo"/>
        </VBox>

        <Separator>
            <VBox.margin><Insets top="24" bottom="24"/></VBox.margin>
        </Separator>

        <!-- Campo: usuario -->
        <VBox spacing="6">
            <Label text="Usuario" styleClass="login-label"/>
            <TextField fx:id="campoUsuario"
                       styleClass="login-campo"
                       promptText="Ingresa tu usuario"
                       onAction="#manejarLogin"/>
        </VBox>

        <!-- Campo: contraseña -->
        <VBox spacing="6">
            <VBox.margin><Insets top="16"/></VBox.margin>
            <Label text="Contraseña" styleClass="login-label"/>
            <PasswordField fx:id="campoContrasena"
                           styleClass="login-campo"
                           promptText="Ingresa tu contraseña"
                           onAction="#manejarLogin"/>
        </VBox>

        <!-- Mensaje de error -->
        <Label fx:id="mensajeError"
               styleClass="login-error"
               text=""
               wrapText="true"
               maxWidth="300">
            <VBox.margin><Insets top="10"/></VBox.margin>
        </Label>

        <!-- Botón ingresar -->
        <Button fx:id="botonIngresar"
                text="Ingresar"
                styleClass="login-boton"
                onAction="#manejarLogin"
                defaultButton="true">
            <VBox.margin><Insets top="24"/></VBox.margin>
        </Button>

        <!-- Separador + enlace a registro -->
        <HBox alignment="CENTER" spacing="6">
            <VBox.margin><Insets top="14"/></VBox.margin>
            <Label text="¿No tienes cuenta?"
                   style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
            <Button text="Regístrate"
                    styleClass="boton-link"
                    onAction="#irARegistro"/>
        </HBox>

        <!-- Versión -->
        <Label text="v1.0 · Proyecto Final ED"
               style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;">
            <VBox.margin><Insets top="12"/></VBox.margin>
        </Label>

    </VBox>

</StackPane>
