<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyectofinal.controllers.ClientesController"
      spacing="16" styleClass="content-area">

    <!-- Encabezado -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Clientes" styleClass="modulo-titulo"/>
            <Label text="Gestión de clientes interesados en propiedades" styleClass="modulo-subtitulo"/>
        </VBox>
        <Button text="➕  Registrar cliente"
                styleClass="boton-primario"
                onAction="#abrirFormularioRegistro"/>
    </HBox>

    <!-- Barra de búsqueda y filtros -->
    <HBox styleClass="barra-filtros" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="campoBusqueda"
                   styleClass="campo-busqueda"
                   promptText="Buscar por nombre, ID o correo..."
                   onKeyReleased="#filtrarTabla"/>
        <ComboBox fx:id="filtroTipoCliente"
                  styleClass="combo-filtro"
                  promptText="Tipo de cliente"
                  onAction="#filtrarTabla"/>
        <ComboBox fx:id="filtroInmuebleDeseado"
                  styleClass="combo-filtro"
                  promptText="Inmueble deseado"
                  onAction="#filtrarTabla"/>
        <ComboBox fx:id="filtroEstadoBusqueda"
                  styleClass="combo-filtro"
                  promptText="Estado de búsqueda"
                  onAction="#filtrarTabla"/>
        <Button text="Limpiar"
                styleClass="boton-secundario"
                onAction="#limpiarFiltros"/>
    </HBox>

    <!-- Tabla de clientes -->
    <TableView fx:id="tablaClientes"
               styleClass="tabla-principal"
               VBox.vgrow="ALWAYS"
              >
        <placeholder><Label text="No hay clientes registrados."/></placeholder>
        <columns>
            <TableColumn fx:id="colIdentificacion"   text="Identificación"    prefWidth="130"/>
            <TableColumn fx:id="colNombre"            text="Nombre"            prefWidth="180"/>
            <TableColumn fx:id="colCorreo"            text="Correo"            prefWidth="190"/>
            <TableColumn fx:id="colTelefono"          text="Teléfono"          prefWidth="110"/>
            <TableColumn fx:id="colTipoCliente"       text="Tipo"              prefWidth="100"/>
            <TableColumn fx:id="colPresupuesto"       text="Presupuesto"       prefWidth="110"/>
            <TableColumn fx:id="colInmuebleDeseado"   text="Inmueble deseado"  prefWidth="130"/>
            <TableColumn fx:id="colEstadoBusqueda"    text="Estado"            prefWidth="110"/>
        </columns>
    </TableView>

    <!-- Barra de acciones inferior -->
    <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
        <Button text="✏️  Editar"
                fx:id="btnEditar"
                styleClass="boton-secundario"
                onAction="#editarClienteSeleccionado"
                disable="true"/>
        <Button text="🗑️  Eliminar"
                fx:id="btnEliminar"
                styleClass="boton-peligro"
                onAction="#eliminarClienteSeleccionado"
                disable="true"/>
        <Button text="📋  Ver historial de interacciones"
                fx:id="btnVerHistorial"
                styleClass="boton-secundario"
                onAction="#verHistorialCliente"
                disable="true"/>
        <Button text="⭐  Ver favoritos"
                fx:id="btnVerFavoritos"
                styleClass="boton-secundario"
                onAction="#verFavoritosCliente"
                disable="true"/>
    </HBox>

</VBox>
