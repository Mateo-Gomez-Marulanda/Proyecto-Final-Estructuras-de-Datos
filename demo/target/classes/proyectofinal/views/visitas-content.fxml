<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyectofinal.controllers.VisitasController"
      spacing="16" styleClass="content-area">

    <!-- Encabezado -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Visitas" styleClass="modulo-titulo"/>
            <Label text="Cola de visitas pendientes y gestión de agenda" styleClass="modulo-subtitulo"/>
        </VBox>
        <Button text="➕  Agendar visita"
                styleClass="boton-primario"
                onAction="#abrirFormularioAgendar"/>
    </HBox>

    <!-- Info de la cola -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" spacing="4" prefWidth="180">
            <Label text="📥" styleClass="stat-icono-ambar"/>
            <Label fx:id="lblTotalCola" text="0" styleClass="stat-numero"/>
            <Label text="En cola (FIFO)" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" prefWidth="180">
            <Label text="✅" styleClass="stat-icono-verde"/>
            <Label fx:id="lblProximaVisita" text="—" styleClass="stat-label"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
            <Label text="Próxima en cola" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <!-- Tabs: Cola pendiente / Todas las visitas -->
    <TabPane fx:id="tabsVisitas" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- Tab 1: Cola de visitas pendientes (FIFO) -->
        <Tab text="📥  Cola de pendientes" fx:id="tabCola">
            <VBox spacing="12" style="-fx-padding: 16 0 0 0;">

                <TableView fx:id="tablaCola"
                           styleClass="tabla-principal"
                           VBox.vgrow="ALWAYS"
                          >
                    <placeholder><Label text="No hay visitas en cola."/></placeholder>
                    <columns>
                        <TableColumn fx:id="colColaPosicion"  text="#"           prefWidth="45"/>
                        <TableColumn fx:id="colColaCodigo"    text="Código"      prefWidth="100"/>
                        <TableColumn fx:id="colColaCliente"   text="Cliente"     prefWidth="170"/>
                        <TableColumn fx:id="colColaInmueble"  text="Inmueble"    prefWidth="170"/>
                        <TableColumn fx:id="colColaFecha"     text="Fecha"       prefWidth="100"/>
                        <TableColumn fx:id="colColaHora"      text="Hora"        prefWidth="80"/>
                        <TableColumn fx:id="colColaAsesor"    text="Asesor"      prefWidth="150"/>
                    </columns>
                </TableView>

                <!-- Acciones de cola -->
                <HBox styleClass="barra-acciones" spacing="10" alignment="CENTER_LEFT">
                    <Label text="Procesar siguiente en cola:"
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Button text="✅  Confirmar"
                            fx:id="btnConfirmar"
                            styleClass="boton-exito"
                            onAction="#confirmarSiguienteVisita"/>
                    <Button text="❌  Cancelar"
                            fx:id="btnCancelar"
                            styleClass="boton-peligro"
                            onAction="#cancelarSiguienteVisita"/>
                    <Button text="🔄  Reprogramar"
                            fx:id="btnReprogramar"
                            styleClass="boton-advertencia"
                            onAction="#reprogramarSiguienteVisita"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- Tab 2: Todas las visitas -->
        <Tab text="📋  Todas las visitas" fx:id="tabTodas">
            <VBox spacing="12" style="-fx-padding: 16 0 0 0;">

                <HBox styleClass="barra-filtros" spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="campoBusquedaTodas"
                               styleClass="campo-busqueda"
                               promptText="Buscar por cliente, inmueble o código..."
                               onKeyReleased="#filtrarTodasVisitas"/>
                    <ComboBox fx:id="filtroEstadoVisita"
                              styleClass="combo-filtro"
                              promptText="Estado"
                              onAction="#filtrarTodasVisitas"/>
                    <Button text="Limpiar" styleClass="boton-secundario" onAction="#limpiarFiltrosVisitas"/>
                </HBox>

                <TableView fx:id="tablaTodasVisitas"
                           styleClass="tabla-principal"
                           VBox.vgrow="ALWAYS"
                          >
                    <placeholder><Label text="No hay visitas registradas."/></placeholder>
                    <columns>
                        <TableColumn fx:id="colTCodigo"    text="Código"    prefWidth="100"/>
                        <TableColumn fx:id="colTCliente"   text="Cliente"   prefWidth="160"/>
                        <TableColumn fx:id="colTInmueble"  text="Inmueble"  prefWidth="160"/>
                        <TableColumn fx:id="colTFecha"     text="Fecha"     prefWidth="100"/>
                        <TableColumn fx:id="colTHora"      text="Hora"      prefWidth="80"/>
                        <TableColumn fx:id="colTAsesor"    text="Asesor"    prefWidth="140"/>
                        <TableColumn fx:id="colTEstado"    text="Estado"    prefWidth="120"/>
                    </columns>
                </TableView>

            </VBox>
        </Tab>

    </TabPane>

</VBox>
