<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="proyectofinal.controllers.ShellController"
            stylesheets="@../css/estilos.css"
            prefWidth="1100" prefHeight="700">

    <!-- ══ SIDEBAR IZQUIERDO ══════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar">

            <!-- Encabezado del sidebar -->
            <VBox styleClass="sidebar-header" spacing="2">
                <Label text="🏠 PropTech" styleClass="sidebar-title"/>
                <Label text="Panel de administración" styleClass="sidebar-subtitle"/>
            </VBox>

            <!-- Navegación principal -->
            <Label text="MENÚ PRINCIPAL" styleClass="nav-section-label"/>

            <Button fx:id="btnDashboard"
                    text="  📊  Dashboard"
                    styleClass="nav-button, nav-button-activo"
                    onAction="#navegarDashboard"
                    maxWidth="Infinity"/>

            <Button fx:id="btnInmuebles"
                    text="  🏢  Inmuebles"
                    styleClass="nav-button"
                    onAction="#navegarInmuebles"
                    maxWidth="Infinity"/>

            <Button fx:id="btnClientes"
                    text="  👤  Clientes"
                    styleClass="nav-button"
                    onAction="#navegarClientes"
                    maxWidth="Infinity"/>

            <Button fx:id="btnAsesores"
                    text="  💼  Asesores"
                    styleClass="nav-button"
                    onAction="#navegarAsesores"
                    maxWidth="Infinity"/>

            <Button fx:id="btnVisitas"
                    text="  📅  Visitas"
                    styleClass="nav-button"
                    onAction="#navegarVisitas"
                    maxWidth="Infinity"/>

            <Button fx:id="btnOperaciones"
                    text="  📋  Operaciones"
                    styleClass="nav-button"
                    onAction="#navegarOperaciones"
                    maxWidth="Infinity"/>

            <Separator>
                <VBox.margin><Insets top="8" bottom="8"/></VBox.margin>
            </Separator>

            <Label text="SISTEMA" styleClass="nav-section-label"/>

            <Button fx:id="btnAlertas"
                    text="  🔔  Alertas"
                    styleClass="nav-button, nav-button-alerta"
                    onAction="#navegarAlertas"
                    maxWidth="Infinity"/>

            <!-- Espaciador -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Pie del sidebar -->
            <VBox styleClass="sidebar-footer" spacing="4">
                <Label fx:id="labelUsuarioActivo"
                       text="Admin"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                <Button text="Cerrar sesión"
                        styleClass="boton-salir"
                        onAction="#cerrarSesion"
                        maxWidth="Infinity"/>
            </VBox>

        </VBox>
    </left>

    <!-- ══ ÁREA DE CONTENIDO CENTRAL ══════════════════════ -->
    <center>
        <!-- Aquí se carga dinámicamente cada módulo -->
        <StackPane fx:id="contenidoCentral" styleClass="content-area"/>
    </center>

</BorderPane>
